<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2A293D"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Plate circle -->
    <item
        android:top="18dp"
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp">
        <shape android:shape="oval">
            <solid android:color="#1E1D30"/>
            <stroke
                android:width="2dp"
                android:color="#3A3950"/>
        </shape>
    </item>

    <!-- Fork line left -->
    <item
        android:top="28dp"
        android:bottom="28dp"
        android:left="32dp"
        android:right="72dp">
        <shape android:shape="rectangle">
            <solid android:color="#4A495D"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>

    <!-- Spoon line right -->
    <item
        android:top="28dp"
        android:bottom="28dp"
        android:left="72dp"
        android:right="32dp">
        <shape android:shape="rectangle">
            <solid android:color="#4A495D"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>

</layer-list>