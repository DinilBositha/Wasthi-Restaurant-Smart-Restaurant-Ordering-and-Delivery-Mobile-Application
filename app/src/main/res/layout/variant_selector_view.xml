<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_background"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/btn_close_bottom_sheet"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end|top"
            android:contentDescription="Close"
            android:padding="4dp"
            android:src="@drawable/close"
            app:tint="@color/md_theme_onSurfaceVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/variant_selector_img"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/anushka2"
                app:shapeAppearanceOverlay="@style/circleImage" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:orientation="vertical">


                <TextView
                    android:id="@+id/variant_selector_food_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kottu"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/variant_selector_food_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Kottu Roti is a popular Sri Lankan street food. It is made by chopping godamba roti into small pieces and mixing it with vegetables, eggs, meat (such as chicken or beef), and spices."
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/variant_selector_food_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Rs 1200.00"
                    android:textColor="@color/md_theme_error"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/variantContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_qty_minus"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:background="@drawable/circle_shape"
                    android:backgroundTint="@color/md_theme_surfaceContainerHighest"
                    android:layout_margin="5dp"
                    android:text="-" />

                <TextView
                    android:id="@+id/variant_food_qty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:text="1"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_qty_plus"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:background="@drawable/circle_shape"
                    android:backgroundTint="@color/md_theme_error"
                    android:text="+"
                    android:layout_margin="5dp"
                    android:textColor="@color/md_theme_background" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/txt_stock_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:textColor="@android:color/darker_gray" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_add"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:enabled="false"
            android:text="Confirm &amp; Add"
            app:cornerRadius="15dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>